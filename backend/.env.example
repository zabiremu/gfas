DATABASE_URL=postgresql://user:password@localhost:5432/amovix_db
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
REDIS_URL=redis://localhost:6379

# STORAGE_DRIVER selects where generated PDF documents are stored:
#   local (default) - filesystem under ./uploads
#   minio            - S3-compatible object storage (see docker-compose.yml's
#                       minio service for local dev credentials)
STORAGE_DRIVER=local
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=amovix-documents

MAIL_HOST=localhost
MAIL_PORT=1025

PORT=3001
