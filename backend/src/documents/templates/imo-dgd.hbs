<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>IMO Dangerous Goods Declaration {{shipmentNumber}}</title>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: Arial, Helvetica, sans-serif;
        color: #1a2433;
        font-size: 11px;
        line-height: 1.4;
        background: #ffffff;
      }
      .page {
        width: 794px;
        margin: 0 auto;
        padding: 0 0 28px;
      }
      .masthead {
        background: #07172e;
        color: #ffffff;
        padding: 20px 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .brand {
        font-size: 20px;
        font-weight: 800;
        letter-spacing: 0.4px;
      }
      .brand small {
        display: block;
        font-size: 10px;
        font-weight: 400;
        opacity: 0.75;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-top: 2px;
      }
      .masthead .doc-meta {
        text-align: right;
        font-size: 10px;
        opacity: 0.85;
      }
      .doc-title {
        text-align: center;
        font-size: 20px;
        font-weight: 800;
        letter-spacing: 2px;
        padding: 14px 0 10px;
        text-transform: uppercase;
        border-bottom: 3px solid #07172e;
      }
      .doc-subbar {
        display: flex;
        justify-content: space-between;
        padding: 8px 28px;
        background: #eef2f7;
        border-bottom: 1px solid #c9d4e0;
        font-size: 11px;
      }
      .doc-subbar strong {
        color: #07172e;
      }
      .content {
        padding: 0 28px;
      }
      .columns {
        display: flex;
        gap: 14px;
        margin-top: 16px;
      }
      .col {
        flex: 1;
      }
      .box {
        border: 1px solid #07172e;
        margin-bottom: 12px;
      }
      .box-label {
        background: #07172e;
        color: #ffffff;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 5px 10px;
      }
      .box-body {
        padding: 10px;
        min-height: 64px;
      }
      .box-body .name {
        font-weight: 700;
        font-size: 12px;
        margin-bottom: 3px;
      }
      .kv {
        display: flex;
        padding: 5px 10px;
        border-bottom: 1px dashed #c9d4e0;
      }
      .kv:last-child {
        border-bottom: none;
      }
      .kv .k {
        width: 180px;
        color: #5b6b80;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .kv .v {
        flex: 1;
        font-weight: 600;
      }
      .regulated {
        border: 2px solid #c0392b;
        margin-top: 16px;
      }
      .regulated .box-label {
        background: #c0392b;
      }
      .regulated .box-body {
        background: #fdf3f2;
        min-height: 0;
        padding: 0;
      }
      .not-regulated {
        margin-top: 16px;
        border: 2px solid #2f8f4e;
        text-align: center;
        padding: 18px;
        color: #1f5c33;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
      }
      .declaration {
        margin-top: 22px;
        border: 1px solid #c9d4e0;
        background: #f7f9fc;
        padding: 12px 14px;
        font-size: 10px;
        color: #3a4759;
      }
      .footer {
        margin-top: 22px;
        border-top: 2px solid #07172e;
        padding-top: 16px;
      }
      .signatures {
        display: flex;
        gap: 28px;
      }
      .sig {
        flex: 1;
      }
      .sig .line {
        border-bottom: 1px solid #1a2433;
        height: 34px;
      }
      .sig .caption {
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #5b6b80;
        margin-top: 4px;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="masthead">
        <div class="brand">
          Amovix
          <small>Global Freight Automation System</small>
        </div>
        <div class="doc-meta">
          DGD No. <strong>{{shipmentNumber}}</strong><br />
          Issued {{issuedDate}}
        </div>
      </div>

      <div class="doc-title">IMO Dangerous Goods Declaration</div>
      <div class="doc-subbar">
        <span>Shipment Number: <strong>{{shipmentNumber}}</strong></span>
        <span>Date Issued: <strong>{{issuedDate}}</strong></span>
      </div>

      <div class="content">
        <div class="columns">
          <div class="col">
            <div class="box">
              <div class="box-label">Shipper / Consignor</div>
              <div class="box-body">
                <div class="name">{{shipper.name}}</div>
                <div>{{shipper.address}}</div>
                <div>{{shipper.city}} {{shipper.state}} {{shipper.country}}</div>
              </div>
            </div>
          </div>
          <div class="col">
            <div class="box">
              <div class="box-label">Consignee</div>
              <div class="box-body">
                <div class="name">{{consignee.name}}</div>
                <div>{{consignee.address}}</div>
                <div>{{consignee.city}} {{consignee.country}}</div>
              </div>
            </div>
          </div>
        </div>

        {{#if isHazmat}}
          <div class="box regulated">
            <div class="box-label">⚠ Dangerous Goods Declaration</div>
            <div class="box-body">
              <div class="kv">
                <span class="k">UN Number</span>
                <span class="v">{{hazmatUnNumber}}</span>
              </div>
              <div class="kv">
                <span class="k">Proper Shipping Name</span>
                <span class="v">{{hazmatProperShippingName}}</span>
              </div>
              <div class="kv">
                <span class="k">IMO/IMDG Class</span>
                <span class="v">{{hazmatClass}}</span>
              </div>
              <div class="kv">
                <span class="k">Packing Group</span>
                <span class="v">{{hazmatPackingGroup}}</span>
              </div>
              <div class="kv">
                <span class="k">Gross Weight</span>
                <span class="v">{{grossWeightKg}} KG</span>
              </div>
              <div class="kv">
                <span class="k">Packages</span>
                <span class="v">{{numPackages}} {{packageType}}</span>
              </div>
            </div>
          </div>

          <div class="declaration">
            I hereby declare that the contents of this consignment are fully
            and accurately described above by proper shipping name and are
            classified, packaged, marked and labelled/placarded, and are in
            all respects in proper condition for transport according to
            applicable international and national governmental regulations.
          </div>
        {{else}}
          <div class="not-regulated">Not Regulated — No Dangerous Goods Declared</div>
        {{/if}}

        <div class="footer">
          <div class="signatures">
            <div class="sig">
              <div class="line"></div>
              <div class="caption">Date</div>
            </div>
            <div class="sig">
              <div class="line"></div>
              <div class="caption">Shipper's Signature</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
