<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Certificate of Origin {{shipmentNumber}}</title>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: Arial, Helvetica, sans-serif;
        color: #1a2433;
        font-size: 11px;
        line-height: 1.4;
        background: #ffffff;
      }
      .page {
        width: 794px;
        margin: 0 auto;
        padding: 0 0 28px;
      }
      .masthead {
        background: #07172e;
        color: #ffffff;
        padding: 20px 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .brand {
        font-size: 20px;
        font-weight: 800;
        letter-spacing: 0.4px;
      }
      .brand small {
        display: block;
        font-size: 10px;
        font-weight: 400;
        opacity: 0.75;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-top: 2px;
      }
      .masthead .doc-meta {
        text-align: right;
        font-size: 10px;
        opacity: 0.85;
      }
      .doc-title {
        text-align: center;
        font-size: 22px;
        font-weight: 800;
        letter-spacing: 3px;
        padding: 14px 0 10px;
        text-transform: uppercase;
        border-bottom: 3px solid #07172e;
      }
      .doc-subbar {
        display: flex;
        justify-content: space-between;
        padding: 8px 28px;
        background: #eef2f7;
        border-bottom: 1px solid #c9d4e0;
        font-size: 11px;
      }
      .doc-subbar strong {
        color: #07172e;
      }
      .content {
        padding: 0 28px;
      }
      .columns {
        display: flex;
        gap: 14px;
        margin-top: 16px;
      }
      .col {
        flex: 1;
      }
      .box {
        border: 1px solid #07172e;
        margin-bottom: 12px;
      }
      .box-label {
        background: #07172e;
        color: #ffffff;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 5px 10px;
      }
      .box-body {
        padding: 10px;
        min-height: 70px;
      }
      .box-body .name {
        font-weight: 700;
        font-size: 12px;
        margin-bottom: 3px;
      }
      .origin-banner {
        margin-top: 16px;
        border: 2px solid #07172e;
        text-align: center;
        padding: 16px;
      }
      .origin-banner .label {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #5b6b80;
      }
      .origin-banner .country {
        font-size: 24px;
        font-weight: 800;
        color: #07172e;
        margin-top: 4px;
      }
      .section-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #07172e;
        margin: 18px 0 8px;
      }
      table.cargo {
        width: 100%;
        border-collapse: collapse;
      }
      table.cargo th {
        background: #07172e;
        color: #ffffff;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 8px 10px;
        text-align: left;
      }
      table.cargo td {
        border: 1px solid #c9d4e0;
        padding: 10px;
        vertical-align: top;
        font-size: 11px;
      }
      table.cargo td.num {
        text-align: right;
        white-space: nowrap;
      }
      .declaration {
        margin-top: 22px;
        border: 1px solid #c9d4e0;
        background: #f7f9fc;
        padding: 12px 14px;
        font-size: 10px;
        color: #3a4759;
      }
      .footer {
        margin-top: 22px;
        border-top: 2px solid #07172e;
        padding-top: 16px;
      }
      .signatures {
        display: flex;
        gap: 28px;
      }
      .sig {
        flex: 1;
      }
      .sig .line {
        border-bottom: 1px solid #1a2433;
        height: 34px;
      }
      .sig .caption {
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #5b6b80;
        margin-top: 4px;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="masthead">
        <div class="brand">
          Amovix
          <small>Global Freight Automation System</small>
        </div>
        <div class="doc-meta">
          Cert No. <strong>{{shipmentNumber}}</strong><br />
          Issued {{issuedDate}}
        </div>
      </div>

      <div class="doc-title">Certificate of Origin</div>
      <div class="doc-subbar">
        <span>Certificate Number: <strong>{{shipmentNumber}}</strong></span>
        <span>Date Issued: <strong>{{issuedDate}}</strong></span>
      </div>

      <div class="content">
        <div class="columns">
          <div class="col">
            <div class="box">
              <div class="box-label">Exporter / Shipper</div>
              <div class="box-body">
                <div class="name">{{shipper.name}}</div>
                <div>{{shipper.address}}</div>
                <div>{{shipper.city}} {{shipper.state}} {{shipper.country}}</div>
              </div>
            </div>
          </div>
          <div class="col">
            <div class="box">
              <div class="box-label">Consignee</div>
              <div class="box-body">
                <div class="name">{{consignee.name}}</div>
                <div>{{consignee.address}}</div>
                <div>{{consignee.city}} {{consignee.country}}</div>
              </div>
            </div>
          </div>
        </div>

        <div class="origin-banner">
          <div class="label">Country of Origin</div>
          <div class="country">{{countryOfOrigin}}</div>
        </div>

        <div class="section-title">Description of Goods</div>
        <table class="cargo">
          <thead>
            <tr>
              <th style="width: 40%;">Description</th>
              <th>HS Code</th>
              <th>Packages</th>
              <th>Gross Weight</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{{goodsDescription}}</td>
              <td>{{hsCode}}</td>
              <td class="num">{{numPackages}} {{packageType}}</td>
              <td class="num">{{grossWeightKg}} KG</td>
            </tr>
          </tbody>
        </table>

        <div class="declaration">
          The undersigned hereby certifies that the goods described above
          originate in the country shown, in accordance with the applicable
          rules of origin, and that all statements herein are true and
          correct.
        </div>

        <div class="footer">
          <div class="signatures">
            <div class="sig">
              <div class="line"></div>
              <div class="caption">Date</div>
            </div>
            <div class="sig">
              <div class="line"></div>
              <div class="caption">Authorized Signature &amp; Stamp</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
