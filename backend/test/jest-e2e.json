{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^puppeteer$": "<rootDir>/mocks/puppeteer.js"
  },
  "globalSetup": "<rootDir>/global-setup.js",
  "setupFiles": ["<rootDir>/env-setup.js"]
}
